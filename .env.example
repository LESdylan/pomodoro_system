# Copy this file to ".env" (which is gitignored) and fill in your values.
# The daemon passes this file to the notifier container via `docker run --env-file`.
# IMPORTANT: docker --env-file takes the RAW value after '=' -- do NOT wrap in quotes.

# ---------- HTML email (optional; all three required to enable) ----------
# For Gmail you MUST use an "App Password" (Google account -> Security ->
# 2-Step Verification -> App passwords), NOT your normal password.
EMAIL=dev.pro.photo@gmail.com
EMAIL_PASSWORD=your_16_char_app_password_no_spaces
EMAIL_RECEIVER=dev.pro.photo@gmail.com

# SMTP server (defaults shown are for Gmail). Port 587 = STARTTLS, 465 = SSL.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ---------- ntfy phone push (optional; NTFY_TOPIC enables it) ----------
# Delivery is by TOPIC, NOT a phone number -- no phone number is involved.
# On your phone: install the "ntfy" app, tap + -> Subscribe to topic, and enter this
# exact string. Anything posted to ntfy.sh/<topic> then lands on your phone.
# Pick something unguessable -- anyone who knows the topic can read/post to it.
NTFY_TOPIC=pomodoro-dlesieur-7f3a9c
# Self-hosted server or auth token are optional:
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOKEN=
